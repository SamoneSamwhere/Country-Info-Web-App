{
  "info": {
    "name": "GlobeScope – Country Info App API",
    "description": "IT 301 Final Project – Complete Postman collection for all backend endpoints.\n\nBase URL: http://localhost:5000\n\nWorkflow:\n1. Register or Login to get a token\n2. Copy the token into the collection variable `token`\n3. All Favorites requests will use it automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health",
            "description": "Check if the API server is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "POST /api/auth/register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Register a new user. Returns 201 + JWT token on success.\n\nStatus Codes:\n- 201: Created\n- 400: Missing fields or short password\n- 409: Email already exists"
          },
          "response": []
        },
        {
          "name": "POST /api/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "description": "Login with email and password. Returns 200 + JWT token on success.\n\nStatus Codes:\n- 200: OK\n- 400: Missing fields\n- 401: Invalid credentials"
          },
          "response": []
        },
        {
          "name": "GET /api/auth/me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/auth/me",
            "description": "Get the currently authenticated user's info.\n\nStatus Codes:\n- 200: OK\n- 401: No/invalid token\n- 404: User not found"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Favorites (CRUD)",
      "item": [
        {
          "name": "GET /api/favorites",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/favorites",
            "description": "Get all favorites for the logged-in user.\n\nStatus Codes:\n- 200: OK (empty array if none)\n- 401: Unauthorized"
          },
          "response": []
        },
        {
          "name": "POST /api/favorites",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/favorites",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"countryCode\": \"PHL\",\n  \"countryName\": \"Philippines\",\n  \"flagUrl\": \"https://flagcdn.com/w320/ph.png\",\n  \"region\": \"Asia\",\n  \"population\": 109581078,\n  \"capital\": \"Manila\",\n  \"note\": \"My home country!\"\n}"
            },
            "description": "Add a country to the user's favorites.\n\nRequired fields: countryCode, countryName\n\nStatus Codes:\n- 201: Created\n- 400: Missing required fields\n- 401: Unauthorized\n- 409: Already in favorites"
          },
          "response": []
        },
        {
          "name": "PATCH /api/favorites/:id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/favorites/REPLACE_WITH_FAVORITE_ID",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Updated note – beautiful archipelago of 7,000+ islands!\"\n}"
            },
            "description": "Update the personal note on a saved favorite.\n\nStatus Codes:\n- 200: OK\n- 401: Unauthorized\n- 404: Favorite not found"
          },
          "response": []
        },
        {
          "name": "DELETE /api/favorites/:id",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/favorites/REPLACE_WITH_FAVORITE_ID",
            "description": "Remove a country from favorites.\n\nStatus Codes:\n- 200: OK\n- 401: Unauthorized\n- 404: Favorite not found"
          },
          "response": []
        }
      ]
    },
    {
      "name": "REST Countries API (External)",
      "item": [
        {
          "name": "GET all countries",
          "request": {
            "method": "GET",
            "url": "https://restcountries.com/v3.1/all?fields=name,cca3,flags,population,region,capital",
            "description": "Fetch all countries with selected fields. Used by Explore page."
          },
          "response": []
        },
        {
          "name": "GET country by name",
          "request": {
            "method": "GET",
            "url": "https://restcountries.com/v3.1/name/philippines",
            "description": "Search countries by name. Used by search bar."
          },
          "response": []
        },
        {
          "name": "GET countries by region",
          "request": {
            "method": "GET",
            "url": "https://restcountries.com/v3.1/region/Asia",
            "description": "Filter countries by region (Africa, Americas, Asia, Europe, Oceania)."
          },
          "response": []
        },
        {
          "name": "GET country by code",
          "request": {
            "method": "GET",
            "url": "https://restcountries.com/v3.1/alpha/PHL",
            "description": "Fetch full details for one country by its 3-letter code. Used by CountryPage."
          },
          "response": []
        }
      ]
    }
  ]
}
